# Backend Configuration Example
# Copy this to .env and fill in your actual values

# Server Port
PORT=3001

# MongoDB Connection
# For local: mongodb://localhost:27017/ai-interview-analyzer
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb://localhost:27017/ai-interview-analyzer

# JWT Secret Key (use a strong, random secret in production)
JWT_SECRET=your_random_secret_key_min_32_chars_12345678901234567890

# OpenAI API Key (optional, for AI-powered resume analysis)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxx

# Environment
NODE_ENV=development
